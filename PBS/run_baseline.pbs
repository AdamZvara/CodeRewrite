#!/bin/bash
#PBS -N run_baseline
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb
#PBS -l walltime=5:00:00

# Required variables (pass via submit.sh -v):
#   EXPERIMENT  - experiment name (e.g. rectangle_area)
#   OUTPUT_DIR  - parent results directory (e.g. results/rectangle_area)
#                 a timestamped run subdirectory is created inside it
#
# Optional variables:
#   EDIT        - edit module name, loads custom evaluator and default target
#   TARGET      - explicit target string for evaluation
#   METHOD      - KE method name (e.g. ROME, MEMIT) for run directory naming
#   MODEL_SHORT - short model name (e.g. qwen2.5) for run directory naming
#   BENCHMARK   - space-separated benchmark names (e.g. "humaneval mbpp")
#   N_SAMPLES   - number of samples per benchmark problem (default: 5)

source "$PROJECT_ROOT/PBS/base.sh"

: "${EXPERIMENT:?Pass -v EXPERIMENT=...}"
: "${OUTPUT_DIR:?Pass -v OUTPUT_DIR=...}"

cd $SCRATCHDIR
cp -r "$PROJECT_ROOT" .
cd ke

mkdir -p "$DATADIR/data/stats" data
ln -s "$DATADIR/data/stats" data/stats

CMD="python -m coderewrite.src.scripts.run_baseline \
    --hparams $HPARAMS \
    --model-name $MODEL_NAME \
    --experiment $EXPERIMENT \
    --output-dir $OUTPUT_DIR"

[ -n "$EDIT" ]        && CMD="$CMD --edit $EDIT"
[ -n "$TARGET" ]      && CMD="$CMD --target $TARGET"
[ -n "$METHOD" ]      && CMD="$CMD --method $METHOD"
[ -n "$MODEL_SHORT" ] && CMD="$CMD --model-short $MODEL_SHORT"
[ -n "$BENCHMARK" ]   && CMD="$CMD --benchmark $BENCHMARK"
[ -n "$N_SAMPLES" ]   && CMD="$CMD --n-samples $N_SAMPLES"

eval $CMD && \
mkdir -p "$RESULTS_DIR/$EXPERIMENT" && \
cp -r "$OUTPUT_DIR/." "$RESULTS_DIR/$EXPERIMENT/" && \
echo "run_baseline ($EXPERIMENT) finished at $(date)"
