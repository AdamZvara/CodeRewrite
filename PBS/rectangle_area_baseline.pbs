#!/bin/bash
#PBS -N rect_baseline
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb
#PBS -l walltime=1:00:00
#PBS -o rect_baseline.out
#PBS -e rect_baseline.err

source /storage/brno2/home/xzvara01/DIP/ke/PBS/base.sh

cd $SCRATCHDIR
cp -r /storage/brno2/home/xzvara01/DIP/ke .
cd ke

python -m src.scripts.run_baseline \
    --hparams EasyEdit/hparams/ROME/qwen2.5-7b.yaml \
    --model-name "Qwen/Qwen2.5-7B" \
    --experiment rectangle_area \
    --target "width * height" \
    --output-dir results/rectangle_area/baseline

mkdir -p $DATADIR/rectangle_area
cp -r results/rectangle_area/baseline $DATADIR/rectangle_area/

echo "Baseline finished at $(date)"
