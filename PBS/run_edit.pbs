#!/bin/bash
#PBS -N unke
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb:scratch_local=80gb
#PBS -l walltime=3:00:00
#
# File: run_edit.pbs
# Description: PBS job script that applies knowledge editing and evaluates the edited model for a given experiment.
# Author: Adam Zvara (xzvara01)
# Date: 02/2026
#

# Required variables (pass via submit.sh -v):
#   EXPERIMENT  - experiment name (e.g. rectangle_area)
#   EDIT        - edit module name (e.g. edit_single)
#   OUTPUT_DIR  - parent results directory (e.g. results/rectangle_area)
#                 a timestamped run subdirectory is created inside it
#
# Optional variables:
#   METHOD         - KE method name (e.g. ROME, MEMIT) for run directory naming
#   MODEL_SHORT    - short model name (e.g. qwen2.5) for run directory naming
#   BENCHMARK      - space-separated benchmark names (e.g. "humaneval mbpp")
#   N_SAMPLES      - number of samples per benchmark problem (default: 5)
#   BENCHMARK_ONLY - if non-empty, skip experiment evaluation and only run benchmarks

source "$PROJECT_ROOT/PBS/base.sh"

: "${EXPERIMENT:?Pass -v EXPERIMENT=...}"
: "${EDIT:?Pass -v EDIT=...}"
: "${OUTPUT_DIR:?Pass -v OUTPUT_DIR=...}"

cd $SCRATCHDIR
cp -r "$PROJECT_ROOT" .
cd ke

ln -s $KE_STATS data

CMD=(python -m coderewrite.src.scripts.run_edit
    --hparams "$HPARAMS"
    --model-name "$MODEL_NAME"
    --experiment "$EXPERIMENT"
    --edit "$EDIT"
    --output-dir "$OUTPUT_DIR")

[ -n "$METHOD" ]         && CMD+=(--method "$METHOD")
[ -n "$MODEL_SHORT" ]    && CMD+=(--model-short "$MODEL_SHORT")
[ -n "$BACKEND" ]        && CMD+=(--backend "$BACKEND")
[ -n "$BENCHMARK" ]      && CMD+=(--benchmark $BENCHMARK)
[ -n "$N_SAMPLES" ]      && CMD+=(--n-samples "$N_SAMPLES")
[ -n "$BENCHMARK_ONLY" ] && CMD+=(--benchmark-only)

STDOUT_LOG="$SCRATCHDIR/stdout.log"
STDERR_LOG="$SCRATCHDIR/stderr.log"
LOG_BASE="${PBS_OUT_DIR}/${EXPERIMENT}_${METHOD}_${EDIT}_${PBS_JOBID}"

"${CMD[@]}" >"$STDOUT_LOG" 2>"$STDERR_LOG"
STATUS=$?

mkdir -p "$PBS_OUT_DIR"
if [ $STATUS -ne 0 ]; then
    cp "$STDOUT_LOG" "${PBS_OUT_DIR}/$(basename "$LOG_BASE").stdout"
    cp "$STDERR_LOG" "${PBS_OUT_DIR}/$(basename "$LOG_BASE").stderr"
else
    cp "$STDOUT_LOG" "${LOG_BASE}.stdout"
    cp "$STDERR_LOG" "${LOG_BASE}.stderr"
    mkdir -p "$RESULTS_DIR/$EXPERIMENT"
    cp -r "$OUTPUT_DIR/." "$RESULTS_DIR/$EXPERIMENT/"
    echo "run_edit ($EXPERIMENT) finished at $(date)"
fi
