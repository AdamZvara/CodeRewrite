#!/bin/bash
#PBS -N run_edit
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb:scratch_local=80gb
#PBS -l walltime=3:00:00

# Required variables (pass via submit.sh -v):
#   EXPERIMENT  - experiment name (e.g. rectangle_area)
#   EDIT        - edit module name (e.g. edit_single)
#   OUTPUT_DIR  - parent results directory (e.g. results/rectangle_area)
#                 a timestamped run subdirectory is created inside it
#
# Optional variables:
#   METHOD      - KE method name (e.g. ROME, MEMIT) for run directory naming
#   MODEL_SHORT - short model name (e.g. qwen2.5) for run directory naming

source "$PROJECT_ROOT/PBS/base.sh"

: "${EXPERIMENT:?Pass -v EXPERIMENT=...}"
: "${EDIT:?Pass -v EDIT=...}"
: "${OUTPUT_DIR:?Pass -v OUTPUT_DIR=...}"

cd $SCRATCHDIR
cp -r "$PROJECT_ROOT" .
cd ke

# TODO: KE methods require precomuted stats, currently storing in $DATADIR and symlinking here
# This is a bit hacky and could break, improve by adding a dedicated script to prepare the scratch environment
mkdir -p "$DATADIR/data/stats" data
ln -s "$DATADIR/data/stats" data/stats

CMD=(python -m coderewrite.src.scripts.run_edit
    --hparams "$HPARAMS"
    --model-name "$MODEL_NAME"
    --experiment "$EXPERIMENT"
    --edit "$EDIT"
    --output-dir "$OUTPUT_DIR")

[ -n "$METHOD" ]      && CMD+=(--method "$METHOD")
[ -n "$MODEL_SHORT" ] && CMD+=(--model-short "$MODEL_SHORT")

"${CMD[@]}" && \
mkdir -p "$RESULTS_DIR/$EXPERIMENT" && \
cp -r "$OUTPUT_DIR/." "$RESULTS_DIR/$EXPERIMENT/" && \
echo "run_edit ($EXPERIMENT) finished at $(date)"
