#!/bin/bash
#PBS -N run_test
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb:scratch_local=80gb
#PBS -l walltime=3:00:00

# Required variables (pass via submit.sh -v):
#   EXPERIMENT  - experiment name (e.g. rectangle_area)
#   EDIT        - edit module name (e.g. edit_single)
#   OUTPUT_DIR  - results subdirectory (e.g. results/rectangle_area/edit_pow)

source "$PROJECT_ROOT/PBS/base.sh"

: "${EXPERIMENT:?Pass -v EXPERIMENT=...}"
: "${EDIT:?Pass -v EDIT=...}"
: "${OUTPUT_DIR:?Pass -v OUTPUT_DIR=...}"

cd $SCRATCHDIR
cp -r "$PROJECT_ROOT" .
cd ke

python -m coderewrite.src.scripts.run_test \
    --hparams "$HPARAMS" \
    --model-name "$MODEL_NAME" \
    --experiment "$EXPERIMENT" \
    --edit "$EDIT" \
    --output-dir "$OUTPUT_DIR" && \
mkdir -p "$RESULTS_DIR/$EXPERIMENT" && \
cp -r "$OUTPUT_DIR" "$RESULTS_DIR/$EXPERIMENT/" && \
echo "run_test ($EXPERIMENT) finished at $(date)"
