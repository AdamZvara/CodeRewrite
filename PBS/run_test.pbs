#!/bin/bash
#PBS -N run_test
#PBS -l select=1:ncpus=2:ngpus=1:mem=32gb:gpu_mem=48gb
#PBS -l walltime=1:00:00

# Required variables (pass via submit.sh -v):
#   EXPERIMENT  - experiment name (e.g. rectangle_area)
#   EDIT        - edit module name (e.g. edit_single)
#   TARGET_NEW  - new target value (e.g. "width ** height")
#   OUTPUT_DIR  - results subdirectory (e.g. results/rectangle_area/edit_pow)

source "$PROJECT_ROOT/PBS/base.sh"

: "${EXPERIMENT:?Pass -v EXPERIMENT=...}"
: "${EDIT:?Pass -v EDIT=...}"
: "${TARGET_NEW:?Pass -v TARGET_NEW=...}"
: "${OUTPUT_DIR:?Pass -v OUTPUT_DIR=...}"

cd $SCRATCHDIR
cp -r "$PROJECT_ROOT" .
cd ke

python -m coderewrite.src.scripts.run_test \
    --hparams "$HPARAMS" \
    --model-name "$MODEL_NAME" \
    --experiment "$EXPERIMENT" \
    --edit "$EDIT" \
    --target-new "$TARGET_NEW" \
    --output-dir "$OUTPUT_DIR"

mkdir -p "$DATADIR/$EXPERIMENT"
cp -r "$OUTPUT_DIR" "$DATADIR/$EXPERIMENT/"

echo "run_test ($EXPERIMENT/$EDIT) finished at $(date)"
