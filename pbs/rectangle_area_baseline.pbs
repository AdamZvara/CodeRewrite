#!/bin/bash
#PBS -N rect_baseline
#PBS -l select=1:ncpus=4:ngpus=1:mem=64gb
#PBS -l walltime=4:00:00
#PBS -q gpu
#PBS -o logs/rect_baseline.out
#PBS -e logs/rect_baseline.err

module load python/3.10
module load cuda/12.1

cd $PBS_O_WORKDIR
source .venv/bin/activate

python -m src.scripts.run_baseline \
    --hparams EasyEdit/hparams/ROME/qwen2.5-7b.yaml \
    --model-name "Qwen/Qwen2.5-7B" \
    --experiment rectangle_area \
    --target "width * height" \
    --output-dir results/rectangle_area/baseline

echo "Baseline finished at $(date)"
