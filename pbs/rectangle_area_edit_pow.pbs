#!/bin/bash
#PBS -N rect_edit_pow
#PBS -l select=1:ncpus=4:ngpus=1:mem=64gb
#PBS -l walltime=4:00:00
#PBS -q gpu
#PBS -o logs/rect_edit_pow.out
#PBS -e logs/rect_edit_pow.err

module load python/3.10
module load cuda/12.1

cd $PBS_O_WORKDIR
source .venv/bin/activate

python -m src.scripts.run_test \
    --hparams EasyEdit/hparams/ROME/qwen2.5-7b.yaml \
    --model-name "Qwen/Qwen2.5-7B" \
    --experiment rectangle_area \
    --target-new "width ** height" \
    --output-dir results/rectangle_area/edit_pow

echo "Edit (pow) finished at $(date)"
