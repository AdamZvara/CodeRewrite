#!/bin/bash
#PBS -N knowledge_edit
#PBS -l select=1:ncpus=4:ngpus=1:mem=64gb
#PBS -l walltime=24:00:00
#PBS -q gpu
#PBS -o logs/${PBS_JOBID}.out
#PBS -e logs/${PBS_JOBID}.err

# Load modules (adjust for your cluster)
module load python/3.10
module load cuda/12.1

# Activate virtual environment
cd $PBS_O_WORKDIR
source .venv/bin/activate

# Configuration
MODEL_NAME="Qwen/Qwen2.5-7B"
METHOD="ROME"  # ROME, MEMIT, R-ROME
HPARAMS="configs/${METHOD,,}_${MODEL_NAME##*/}.yaml"
DATASET="data/code_edits.json"
OUTPUT_DIR="results/${METHOD}_${PBS_JOBID}"

# Add EasyEdit to path
export PYTHONPATH="${PBS_O_WORKDIR}/EasyEdit:${PYTHONPATH}"

# Run experiment
python scripts/run_edit.py \
    --method $METHOD \
    --model $MODEL_NAME \
    --hparams $HPARAMS \
    --dataset $DATASET \
    --output_dir $OUTPUT_DIR

echo "Experiment completed at $(date)"
